{
  "headers": [
    {
      "source": "/(.*).html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "Pragma", "value": "no-cache" },
        { "key": "Expires", "value": "0" }
      ]
    },
    {
      "source": "/",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/portal",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/", "destination": "/lidor_v2.html" },
    { "source": "/portal", "destination": "/shoreshim_portal.html" },
    { "source": "/portal/", "destination": "/shoreshim_portal.html" },
    { "source": "/lidor.png", "destination": "/lidor.png.png" }
  ]
}
